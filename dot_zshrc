export LANG=en_US.UTF-8
export LC_TIME=zh_CN.UTF-8
export LC_MONETARY=zh_CN.UTF-8
export LC_MESSAGES=en_US.UTF-8

HOMEBREW_PREFIX=${HOMEBREW_PREFIX:-/opt/homebrew}

source-if-exists() {
  [[ -r $1 ]] && source "$1"
}

typeset -U path fpath
path=($HOMEBREW_PREFIX/opt/rustup/bin $path)
fpath=($HOMEBREW_PREFIX/share/zsh/site-functions $fpath)

autoload -Uz compinit
compinit

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=$HISTSIZE
setopt incappendhistory histignorealldups histsavenodups histfindnodups

source-if-exists "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
if [[ -t 0 && -t 1 ]]; then
  source-if-exists "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
  source-if-exists "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"
fi

eval "$(zoxide init zsh)"
eval "$(starship init zsh)"
eval "$(direnv hook zsh)"
eval "$($HOMEBREW_PREFIX/bin/mise activate zsh)"

source-if-exists "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

alias ..='cd ..'
alias ...='cd ../..'

alias l='eza'
alias la='eza -a'
alias ll='eza -al'

alias cls='clear'

alias lg='lazygit'
alias dotfiles='chezmoi'
alias j='just'
alias claude-auto='claude --enable-auto-mode'

alias zz='zellij'
alias za='zellij attach'
alias zl='zellij list-sessions'
alias zk='zellij kill-all-sessions' # 快速清空后台
alias zw='zellij attach -c work'
alias zn='zellij attach -c $(basename "$PWD")'

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

set-proxy() {
  export ALL_PROXY="socks5://127.0.0.1:10808"
  export HTTP_PROXY="http://127.0.0.1:10809"
  export HTTPS_PROXY="$HTTP_PROXY" WS_PROXY="$HTTP_PROXY" WSS_PROXY="$HTTPS_PROXY"
  export all_proxy="$ALL_PROXY" http_proxy="$HTTP_PROXY" https_proxy="$HTTPS_PROXY"
  export ws_proxy="$WS_PROXY" wss_proxy="$WSS_PROXY"
}

reset-proxy() {
  unset ALL_PROXY HTTP_PROXY HTTPS_PROXY WS_PROXY WSS_PROXY
  unset all_proxy http_proxy https_proxy ws_proxy wss_proxy
}

eval "$($HOMEBREW_PREFIX/Caskroom/miniconda/base/bin/conda shell.zsh hook)"
