LANG=en_US.UTF-8
LC_TIME=zh_CN.UTF-8
LC_MONETARY=zh_CN.UTF-8
LC_MESSAGES=en_US.UTF-8

# 补全大小写不敏感
autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# 持久化zsh history
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory

# plugin
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source <(fzf --zsh)
eval "$(zoxide init zsh)"

# 启用彩色提示符
autoload -U colors && colors
# 每次刷新提示符
setopt prompt_subst
# 设置提示符
PROMPT='%{$fg[yellow]%}%1~ ➤ '

eval "$(starship init zsh)"

# 默认编辑器
export EDITOR=nvim

# ------------------------------------------------------------------------------
# alias
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
alias .......='cd ../../../../../..'
alias ........='cd ../../../../../../..'

alias l='eza'
alias la='eza -a'
alias ll='eza -al'

alias cls='clear'

alias lg='lazygit'
alias dotfiles="chezmoi"
alias j="just"

alias zz='zellij attach -c || zellij'

alias claude-root="claude --dangerously-skip-permissions"
alias claude-auto="claude --enable-auto-mode"

# ===============================
set-proxy () {
  export ALL_PROXY="socks5://127.0.0.1:10808"
  export HTTP_PROXY="http://127.0.0.1:10809"
  export HTTPS_PROXY="http://127.0.0.1:10809"
  git config --global http.https://github.com.proxy http://127.0.0.1:10809
}

reset-proxy () {
  unset ALL_PROXY
  unset HTTP_PROXY
  unset HTTPS_PROXY
  git config --global --unset http.https://github.com.proxy
}

# ===============================
# KDE Desktop Control
# ===============================

kde-on() {
    echo "Switching to Desktop Mode..."
    sudo systemctl set-default graphical.target
    sudo systemctl start sddm
}

kde-off() {
    echo "Switching to CLI Mode..."
    sudo systemctl set-default multi-user.target
    sudo systemctl stop sddm
}

kde-status() {
    systemctl status sddm --no-pager
}

export RUSTUP_UPDATE_ROOT=https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup
export RUSTUP_DIST_SERVER=https://mirrors.tuna.tsinghua.edu.cn/rustup

export PATH="$HOME/.local/bin:$PATH"
