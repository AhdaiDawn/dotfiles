[credential]
	helper = libsecret

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3

[pull]
	rebase = true

[diff]
	tool = nvimdiff

[difftool]
	prompt = false

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
