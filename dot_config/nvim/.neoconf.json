{
  "$schema": "https://raw.githubusercontent.com/folke/neoconf.nvim/main/schemas/neoconf.json",
  "lspconfig": {
    "lua_ls": {
      "enabled": true,
      "settings": {
        "Lua": {
          "runtime": {
            "version": "LuaJIT"
          },
          "workspace": {
            "library": [
              "${3rd}/luv/library",
              "${3rd}/busted/library",
              "${3rd}/luassert/library"
            ],
            "checkThirdParty": false
          },
          "diagnostics": {
            "globals": [
              "vim",
              "describe",
              "it",
              "before_each",
              "after_each"
            ],
            "disable": ["lowercase-global"]
          },
          "completion": {
            "callSnippet": "Replace",
            "keywordSnippet": "Replace"
          },
          "format": {
            "enable": false
          },
          "hint": {
            "enable": true,
            "setType": true
          },
          "telemetry": {
            "enable": false
          }
        }
      }
    }
  }
}
